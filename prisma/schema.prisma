// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// ENUMS
// ==========================================
enum Role {
  coordinator
  student
  lecturer
  external_panelist
}

enum PanelType {
  internal
  external
}

enum PortalPanelType {
  seminar
  project
}

enum InvitationStatus {
  pending
  accepted
  declined
}

enum TopicProposalStatus {
  pending
  approved
  declined
}

enum BatchStatus {
  pending_confirmation
  pending_review
  reviewed
  approved
  declined
}

enum ChapterState {
  locked
  open
  submitted
  approved
  declined
}

enum SenderRole {
  coordinator
  supervisor
}

enum RecipientType {
  all
  students
  supervisors
  seminar_panelists
  project_panelists
  project_group
}

enum NotificationType {
  account_activated
  seminar_portal_opened
  project_portal_opened
  seminar_proposal_slot_opened
  project_proposal_slot_opened
  seminar_proposal_approved
  seminar_batch_declined
  project_proposal_approved
  project_batch_declined
  chapter_opened
  chapter_approved
  chapter_declined
  technical_file_approved
  technical_file_declined
  subgroup_invitation
  submission_confirmation_request
  submission_expired
  final_submission_successful
  chapter_submitted
  technical_file_submitted
  final_submission_received
  defense_files_available
  defense_scores_open
  all_groups_submission_complete
}

// ==========================================
// 1. USER TABLES
// ==========================================
model Cohort {
  id            String   @id @default(uuid())
  name          String
  academic_year String
  created_at    DateTime @default(now())

  students           Student[]
  lecturers          Lecturer[]
  external_panelists ExternalPanelist[]
  seminar_groups     SeminarGroup[]
  project_groups     ProjectGroup[]
  portal_state       PortalState?

  @@map("cohorts")
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  password          String
  role              Role
  is_activated      Boolean  @default(false)
  profile_completed Boolean  @default(false)
  created_at        DateTime @default(now())

  coordinator       Coordinator?
  student           Student?
  lecturer          Lecturer?
  external_panelist ExternalPanelist?
  sent_messages     Message[]
  notifications     Notification[]

  @@map("users")
}

model Coordinator {
  id      String @id @default(uuid())
  user_id String @unique
  name    String

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("coordinators")
}

model Student {
  mat_number   String  @id
  user_id      String  @unique
  surname      String
  firstname    String
  othername    String?
  email        String
  phone_number String
  level        String?
  cohort_id    String

  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  cohort Cohort @relation(fields: [cohort_id], references: [id])

  seminar_group_memberships SeminarGroupMember[]
  project_group_memberships ProjectGroupMember[]
  subgroup_memberships      SubgroupMember[]
  seminar_proposal_batches  SeminarProposalBatch[]
  seminar_reports           SeminarReport[]

  supervisor_configs      SupervisorProjectConfiguration[]
  proposal_batches        ProposalBatch[]
  proposal_confirmations  ProposalConfirmation[]
  chapters                Chapter[]
  chapter_submissions     ChapterSubmission[]
  chapter_confirmations   ChapterConfirmation[]
  technical_submissions   TechnicalFileSubmission[]
  technical_confirmations TechnicalFileConfirmation[]
  final_submissions       FinalSubmission[]
  final_confirmations     FinalSubmissionConfirmation[]

  @@index([cohort_id])
  @@map("students")
}

model Lecturer {
  id                     String   @id @default(uuid())
  name                   String
  title                  String?
  area_of_specialization String
  phone                  String?
  email                  String?  @unique
  cohort_id              String?
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  user_id String @unique
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  cohort  Cohort? @relation(fields: [cohort_id], references: [id])

  supervisors     Supervisor[]
  seminar_panels  SeminarPanelist[]
  project_panels  ProjectPanelist[]

  @@index([cohort_id])
  @@map("lecturers")
}

model ExternalPanelist {
  id             String   @id @default(uuid())
  name           String
  title          String?
  specialization String?
  phone          String?
  email          String   @unique
  cohort_id      String
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  user_id String @unique
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  cohort  Cohort @relation(fields: [cohort_id], references: [id])

  seminar_panels SeminarPanelist[]
  project_panels ProjectPanelist[]

  @@index([cohort_id])
  @@map("external_panelists")
}

model Supervisor {
  id               String @id @default(uuid())
  lecturer_id      String
  project_group_id String

  lecturer      Lecturer     @relation(fields: [lecturer_id], references: [id], onDelete: Cascade)
  project_group ProjectGroup @relation(fields: [project_group_id], references: [id], onDelete: Cascade)
  configurations SupervisorProjectConfiguration[]

  @@index([lecturer_id])
  @@index([project_group_id])
  @@map("supervisors")
}

model SeminarPanelist {
  id                   String    @id @default(uuid())
  type                 PanelType
  lecturer_id          String?
  external_panelist_id String?
  panel_id             String

  lecturer          Lecturer?         @relation(fields: [lecturer_id], references: [id], onDelete: Cascade)
  external_panelist ExternalPanelist? @relation(fields: [external_panelist_id], references: [id], onDelete: Cascade)
  panel             Panel             @relation(fields: [panel_id], references: [id], onDelete: Cascade)

  panel_memberships PanelMember[]
  scores            Score[]
  feedbacks         DefenseFeedback[]

  @@index([panel_id])
  @@map("seminar_panelists")
}

model ProjectPanelist {
  id                   String    @id @default(uuid())
  type                 PanelType
  lecturer_id          String?
  external_panelist_id String?
  panel_id             String

  lecturer          Lecturer?         @relation(fields: [lecturer_id], references: [id], onDelete: Cascade)
  external_panelist ExternalPanelist? @relation(fields: [external_panelist_id], references: [id], onDelete: Cascade)
  panel             Panel             @relation(fields: [panel_id], references: [id], onDelete: Cascade)

  panel_memberships PanelMember[]
  scores            Score[]
  feedbacks         DefenseFeedback[]

  @@index([panel_id])
  @@map("project_panelists")
}

// ==========================================
// 2. GROUP TABLES
// ==========================================
model SeminarGroup {
  id         String   @id @default(uuid())
  name       String
  cohort_id  String
  created_at DateTime @default(now())

  cohort  Cohort               @relation(fields: [cohort_id], references: [id])
  members SeminarGroupMember[]

  @@index([cohort_id])
  @@map("seminar_groups")
}

model ProjectGroup {
  id         String   @id @default(uuid())
  name       String
  cohort_id  String
  created_at DateTime @default(now())

  cohort      Cohort               @relation(fields: [cohort_id], references: [id])
  members     ProjectGroupMember[]
  subgroups   Subgroup[]
  supervisors Supervisor[]
  chapters    Chapter[]
  messages    Message[]

  @@index([cohort_id])
  @@map("project_groups")
}

model SeminarGroupMember {
  id                 String @id @default(uuid())
  seminar_group_id   String
  student_mat_number String

  seminar_group SeminarGroup @relation(fields: [seminar_group_id], references: [id], onDelete: Cascade)
  student       Student      @relation(fields: [student_mat_number], references: [mat_number], onDelete: Cascade)

  @@unique([seminar_group_id, student_mat_number])
  @@index([seminar_group_id])
  @@index([student_mat_number])
  @@map("seminar_group_members")
}

model ProjectGroupMember {
  id                 String @id @default(uuid())
  project_group_id   String
  student_mat_number String

  project_group ProjectGroup @relation(fields: [project_group_id], references: [id], onDelete: Cascade)
  student       Student      @relation(fields: [student_mat_number], references: [mat_number], onDelete: Cascade)

  @@unique([project_group_id, student_mat_number])
  @@index([project_group_id])
  @@index([student_mat_number])
  @@map("project_group_members")
}

model Subgroup {
  id               String   @id @default(uuid())
  project_group_id String
  name             String
  is_active        Boolean  @default(false)
  created_at       DateTime @default(now())

  project_group ProjectGroup   @relation(fields: [project_group_id], references: [id], onDelete: Cascade)
  members       SubgroupMember[]

  supervisor_configs    SupervisorProjectConfiguration[]
  proposal_batches      ProposalBatch[]
  chapters              Chapter[]
  chapter_submissions   ChapterSubmission[]
  technical_submissions TechnicalFileSubmission[]
  final_submissions     FinalSubmission[]

  @@index([project_group_id])
  @@map("subgroups")
}

model SubgroupMember {
  id                 String           @id @default(uuid())
  subgroup_id        String
  student_mat_number String
  invitation_status  InvitationStatus @default(pending)
  joined_at          DateTime?

  subgroup Subgroup @relation(fields: [subgroup_id], references: [id], onDelete: Cascade)
  student  Student  @relation(fields: [student_mat_number], references: [mat_number], onDelete: Cascade)

  @@unique([subgroup_id, student_mat_number])
  @@index([subgroup_id])
  @@map("subgroup_members")
}

// ==========================================
// 3. PORTAL STATE TABLE
// ==========================================
model PortalState {
  id                  String   @id @default(uuid())
  cohort_id           String   @unique
  seminar_portal_open Boolean  @default(false)
  project_portal_open Boolean  @default(false)
  updated_at          DateTime @updatedAt

  cohort Cohort @relation(fields: [cohort_id], references: [id], onDelete: Cascade)

  @@map("portal_states")
}

// ==========================================
// 4. SEMINAR TABLES
// ==========================================
model SeminarProposalBatch {
  id                 String   @id @default(uuid())
  student_mat_number String
  batch_number       Int
  submitted_at       DateTime @default(now())

  student   Student           @relation(fields: [student_mat_number], references: [mat_number], onDelete: Cascade)
  proposals SeminarProposal[]

  @@index([student_mat_number])
  @@map("seminar_proposal_batches")
}

model SeminarProposal {
  id                  String              @id @default(uuid())
  batch_id            String
  title               String
  description         String
  status              TopicProposalStatus @default(pending)
  coordinator_comment String?
  reviewed_at         DateTime?

  batch SeminarProposalBatch @relation(fields: [batch_id], references: [id], onDelete: Cascade)

  @@index([batch_id])
  @@map("seminar_proposals")
}

model SeminarReport {
  id                 String   @id @default(uuid())
  student_mat_number String
  submitted_at       DateTime @default(now())

  student Student             @relation(fields: [student_mat_number], references: [mat_number], onDelete: Cascade)
  files   SeminarReportFile[]

  @@index([student_mat_number])
  @@map("seminar_reports")
}

model SeminarReportFile {
  id          String   @id @default(uuid())
  report_id   String
  file_name   String
  file_url    String
  uploaded_at DateTime @default(now())

  report SeminarReport @relation(fields: [report_id], references: [id], onDelete: Cascade)

  @@index([report_id])
  @@map("seminar_report_files")
}

// ==========================================
// 5. PROJECT TABLES
// ==========================================
model SupervisorProjectConfiguration {
  id                 String   @id @default(uuid())
  supervisor_id      String
  student_mat_number String?
  subgroup_id        String?
  proposal_batch_size Int?
  is_any             Boolean  @default(false)
  created_at         DateTime @default(now())

  supervisor Supervisor @relation(fields: [supervisor_id], references: [id], onDelete: Cascade)
  student    Student?   @relation(fields: [student_mat_number], references: [mat_number], onDelete: Cascade)
  subgroup   Subgroup?  @relation(fields: [subgroup_id], references: [id], onDelete: Cascade)

  @@index([supervisor_id])
  @@map("supervisor_project_configurations")
}

model ProposalBatch {
  id                 String      @id @default(uuid())
  student_mat_number String?
  subgroup_id        String?
  batch_number       Int
  status             BatchStatus @default(pending_confirmation)
  submitted_at       DateTime    @default(now())
  expires_at         DateTime?

  student       Student?               @relation(fields: [student_mat_number], references: [mat_number], onDelete: Cascade)
  subgroup      Subgroup?              @relation(fields: [subgroup_id], references: [id], onDelete: Cascade)
  proposals     Proposal[]
  confirmations ProposalConfirmation[]

  @@index([student_mat_number])
  @@index([subgroup_id])
  @@map("proposal_batches")
}

model Proposal {
  id                 String              @id @default(uuid())
  batch_id           String
  title              String
  file_url           String
  status             TopicProposalStatus @default(pending)
  supervisor_comment String?
  reviewed_at        DateTime?

  batch ProposalBatch @relation(fields: [batch_id], references: [id], onDelete: Cascade)

  @@index([batch_id])
  @@map("proposals")
}

model ProposalConfirmation {
  id                 String   @id @default(uuid())
  batch_id           String
  student_mat_number String
  confirmed_at       DateTime @default(now())

  batch   ProposalBatch @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  student Student       @relation(fields: [student_mat_number], references: [mat_number], onDelete: Cascade)

  @@index([batch_id])
  @@map("proposal_confirmations")
}

model Chapter {
  id                 String       @id @default(uuid())
  project_group_id   String
  subgroup_id        String?
  student_mat_number String?
  chapter_number     Int
  status             ChapterState @default(locked)
  opened_at          DateTime?

  project_group ProjectGroup        @relation(fields: [project_group_id], references: [id], onDelete: Cascade)
  subgroup      Subgroup?           @relation(fields: [subgroup_id], references: [id], onDelete: Cascade)
  student       Student?            @relation(fields: [student_mat_number], references: [mat_number], onDelete: Cascade)
  submissions   ChapterSubmission[]

  @@index([project_group_id])
  @@map("chapters")
}

model ChapterSubmission {
  id                 String      @id @default(uuid())
  chapter_id         String
  student_mat_number String?
  subgroup_id        String?
  file_url           String
  submission_number  Int
  status             BatchStatus @default(pending_confirmation)
  supervisor_comment String?
  submitted_at       DateTime    @default(now())
  expires_at         DateTime?

  chapter       Chapter               @relation(fields: [chapter_id], references: [id], onDelete: Cascade)
  student       Student?              @relation(fields: [student_mat_number], references: [mat_number], onDelete: Cascade)
  subgroup      Subgroup?             @relation(fields: [subgroup_id], references: [id], onDelete: Cascade)
  confirmations ChapterConfirmation[]

  @@index([chapter_id])
  @@map("chapter_submissions")
}

model ChapterConfirmation {
  id                    String   @id @default(uuid())
  chapter_submission_id String
  student_mat_number    String
  confirmed_at          DateTime @default(now())

  submission ChapterSubmission @relation(fields: [chapter_submission_id], references: [id], onDelete: Cascade)
  student    Student           @relation(fields: [student_mat_number], references: [mat_number], onDelete: Cascade)

  @@index([chapter_submission_id])
  @@map("chapter_confirmations")
}

model TechnicalFileSubmission {
  id                 String      @id @default(uuid())
  student_mat_number String?
  subgroup_id        String?
  file_url           String?
  link_url           String?
  submission_number  Int
  status             BatchStatus @default(pending_confirmation)
  supervisor_comment String?
  submitted_at       DateTime    @default(now())
  expires_at         DateTime?

  student       Student?                    @relation(fields: [student_mat_number], references: [mat_number], onDelete: Cascade)
  subgroup      Subgroup?                   @relation(fields: [subgroup_id], references: [id], onDelete: Cascade)
  confirmations TechnicalFileConfirmation[]

  @@index([student_mat_number])
  @@map("technical_file_submissions")
}

model TechnicalFileConfirmation {
  id                           String   @id @default(uuid())
  technical_file_submission_id String
  student_mat_number           String
  confirmed_at                 DateTime @default(now())

  submission TechnicalFileSubmission @relation(fields: [technical_file_submission_id], references: [id], onDelete: Cascade)
  student    Student                 @relation(fields: [student_mat_number], references: [mat_number], onDelete: Cascade)

  @@index([technical_file_submission_id])
  @@map("technical_file_confirmations")
}

model FinalSubmission {
  id                 String    @id @default(uuid())
  student_mat_number String?
  subgroup_id        String?
  research_file_url  String
  technical_file_url String?
  technical_link_url String?
  submitted_at       DateTime  @default(now())
  expires_at         DateTime?

  student       Student?                      @relation(fields: [student_mat_number], references: [mat_number], onDelete: Cascade)
  subgroup      Subgroup?                     @relation(fields: [subgroup_id], references: [id], onDelete: Cascade)
  confirmations FinalSubmissionConfirmation[]

  @@index([student_mat_number])
  @@map("final_submissions")
}

model FinalSubmissionConfirmation {
  id                  String   @id @default(uuid())
  final_submission_id String
  student_mat_number  String
  confirmed_at        DateTime @default(now())

  submission FinalSubmission @relation(fields: [final_submission_id], references: [id], onDelete: Cascade)
  student    Student         @relation(fields: [student_mat_number], references: [mat_number], onDelete: Cascade)

  @@index([final_submission_id])
  @@map("final_submission_confirmations")
}

// ==========================================
// 6. DEFENSE TABLES
// ==========================================
model Panel {
  id               String          @id @default(uuid())
  group_id         String
  panel_type       PortalPanelType
  files_available  Boolean         @default(false)
  scores_available Boolean         @default(false)
  created_at       DateTime        @default(now())

  seminar_panelists SeminarPanelist[]
  project_panelists ProjectPanelist[]
  members           PanelMember[]
  rubrics           ScoringRubric[]
  scores            Score[]
  feedbacks         DefenseFeedback[]

  @@index([group_id])
  @@map("panels")
}

model PanelMember {
  id                  String  @id @default(uuid())
  panel_id            String
  seminar_panelist_id String?
  project_panelist_id String?

  panel            Panel            @relation(fields: [panel_id], references: [id], onDelete: Cascade)
  seminar_panelist SeminarPanelist? @relation(fields: [seminar_panelist_id], references: [id], onDelete: Cascade)
  project_panelist ProjectPanelist? @relation(fields: [project_panelist_id], references: [id], onDelete: Cascade)

  @@index([panel_id])
  @@map("panel_members")
}

model ScoringRubric {
  id         String   @id @default(uuid())
  panel_id   String
  created_at DateTime @default(now())

  panel    Panel              @relation(fields: [panel_id], references: [id], onDelete: Cascade)
  criteria ScoringCriterion[]

  @@index([panel_id])
  @@map("scoring_rubrics")
}

model ScoringCriterion {
  id             String @id @default(uuid())
  rubric_id      String
  criterion_name String
  max_score      Int

  rubric ScoringRubric @relation(fields: [rubric_id], references: [id], onDelete: Cascade)
  scores Score[]

  @@index([rubric_id])
  @@map("scoring_criteria")
}

model Score {
  id                  String   @id @default(uuid())
  panel_id            String
  seminar_panelist_id String?
  project_panelist_id String?
  student_mat_number  String?
  subgroup_id         String?
  criterion_id        String
  score               Int
  submitted_at        DateTime @default(now())

  panel            Panel            @relation(fields: [panel_id], references: [id], onDelete: Cascade)
  criterion        ScoringCriterion @relation(fields: [criterion_id], references: [id], onDelete: Cascade)
  seminar_panelist SeminarPanelist? @relation(fields: [seminar_panelist_id], references: [id], onDelete: Cascade)
  project_panelist ProjectPanelist? @relation(fields: [project_panelist_id], references: [id], onDelete: Cascade)

  @@index([panel_id])
  @@map("scores")
}

model DefenseFeedback {
  id                  String   @id @default(uuid())
  panel_id            String
  seminar_panelist_id String?
  project_panelist_id String?
  student_mat_number  String?
  subgroup_id         String?
  feedback_text       String
  is_locked           Boolean  @default(false)
  submitted_at        DateTime @default(now())

  panel            Panel            @relation(fields: [panel_id], references: [id], onDelete: Cascade)
  seminar_panelist SeminarPanelist? @relation(fields: [seminar_panelist_id], references: [id], onDelete: Cascade)
  project_panelist ProjectPanelist? @relation(fields: [project_panelist_id], references: [id], onDelete: Cascade)

  @@index([panel_id])
  @@map("defense_feedbacks")
}

// ==========================================
// 7. MESSAGING & NOTIFICATIONS
// ==========================================
model Message {
  id                 String        @id @default(uuid())
  sender_id          String
  sender_role        SenderRole
  recipient_type     RecipientType
  recipient_group_id String?
  subject            String?
  content            String
  created_at         DateTime      @default(now())

  sender        User          @relation(fields: [sender_id], references: [id])
  project_group ProjectGroup? @relation(fields: [recipient_group_id], references: [id])

  @@index([sender_id])
  @@map("messages")
}

model Notification {
  id           String           @id @default(uuid())
  recipient_id String
  type         NotificationType
  message      String
  action_url   String?
  is_read      Boolean          @default(false)
  created_at   DateTime         @default(now())

  recipient User @relation(fields: [recipient_id], references: [id])

  @@index([recipient_id])
  @@map("notifications")
}
